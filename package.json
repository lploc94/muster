{
  "name": "muster",
  "displayName": "Muster",
  "version": "0.1.0",
  "publisher": "tlelabs",
  "license": "MIT",
  "description": "Muster \u2014 an open-source coordinator for multiple AI CLIs (Claude, Grok, Codex, Antigravity) with streaming and session resume",
  "repository": {
    "type": "git",
    "url": "https://github.com/lploc94/muster.git"
  },
  "bugs": {
    "url": "https://github.com/lploc94/muster/issues"
  },
  "homepage": "https://github.com/lploc94/muster#readme",
  "keywords": [
    "vscode-extension",
    "claude",
    "grok",
    "codex",
    "antigravity",
    "mcp",
    "ai-cli",
    "coordinator"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:muster.presentation"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "muster.openChat",
        "title": "Muster: Open Chat"
      },
      {
        "command": "muster.backupDatabase",
        "title": "Muster: Back Up Global Database"
      },
      {
        "command": "muster.developerResetGlobalDatabase",
        "title": "Muster: Developer Reset Global Database"
      }
    ],
    "configuration": {
      "title": "Muster",
      "properties": {
        "muster.composerSelection": {
          "type": "object",
          "default": {},
          "scope": "application",
          "description": "Last-used composer backend and model for new tasks. Model null/empty means the backend default.",
          "properties": {
            "backend": {
              "type": "string",
              "enum": [
                "claude",
                "grok",
                "kiro",
                "codex",
                "opencode"
              ]
            },
            "model": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "muster.execution.runLimit": {
          "type": "string",
          "enum": [
            "15m",
            "30m",
            "1h",
            "2h",
            "4h",
            "8h"
          ],
          "enumDescriptions": [
            "15 minutes",
            "30 minutes",
            "1 hour",
            "2 hours",
            "4 hours",
            "8 hours"
          ],
          "default": "2h",
          "scope": "resource",
          "description": "Maximum uninterrupted agent run. Applies to newly promoted runs; running turns keep their frozen deadline."
        },
        "muster.execution.maxConcurrentPerBackend": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 32,
          "scope": "resource",
          "description": "Maximum concurrent agent turns per ACP backend. Applies on each scheduling pass; already-running turns are not preempted when lowered. Bounded by shared ACP process capacity."
        },
        "muster.execution.maxConcurrentTurns": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 64,
          "scope": "resource",
          "description": "Maximum concurrent agent turns across all backends. Applies on each scheduling pass; already-running turns are not preempted when lowered."
        },
        "muster.execution.maxConcurrentPerRoot": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 64,
          "scope": "resource",
          "description": "Maximum concurrent agent turns under a single root task tree. Applies on each scheduling pass; already-running turns are not preempted when lowered."
        },
        "muster.execution.fallbacks": {
          "type": "array",
          "default": [],
          "maxItems": 8,
          "scope": "resource",
          "description": "Ordered backend/model fallbacks used after safe same-backend retries are exhausted. Each binding is attempted at most once per recovery chain.",
          "items": {
            "type": "object",
            "required": [
              "backend"
            ],
            "additionalProperties": false,
            "properties": {
              "backend": {
                "type": "string",
                "description": "ACP backend id."
              },
              "model": {
                "type": "string",
                "description": "Optional model id; omit to use the backend default."
              }
            }
          }
        },
        "muster.retention.maxRetainedTurnsPerTask": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "Maximum persisted turns retained per completed task."
        },
        "muster.retention.maxStoredOutputChars": {
          "type": "number",
          "default": 200000,
          "minimum": 1024,
          "description": "Maximum stored assistant output characters per settled turn on open tasks."
        },
        "muster.verification.hostRun": {
          "type": "boolean",
          "default": false,
          "description": "Allow the host to execute a task's verification commands (workspace-trusted, allowlisted runners only)."
        },
        "muster.permissions.mode": {
          "type": "string",
          "enum": [
            "ask",
            "allow",
            "readonly"
          ],
          "default": "ask",
          "enumDescriptions": [
            "Safe: auto-allow read-only tool calls, prompt for writes/commands/unknown actions.",
            "Auto-approve every tool-permission request (least safe; still audit-logged).",
            "Allow read-only tool calls, deny all writes/commands without prompting."
          ],
          "description": "How Muster handles agent tool-permission requests. 'ask' (safe): auto-allow read-only, prompt for writes/commands. 'allow': auto-approve everything (less safe). 'readonly': deny all writes/commands."
        },
        "muster.taskTypes": {
          "type": "object",
          "default": {
            "coordinate": {
              "description": "Coordinate multi-step work; create and wait on children",
              "backend": "opencode",
              "role": "coordinator",
              "briefKind": "coordinate"
            },
            "plan": {
              "description": "Produce an actionable implementation plan",
              "backend": "codex",
              "briefKind": "plan"
            },
            "breakdown": {
              "description": "Decompose a plan into a structured checklist of implement tasks",
              "backend": "codex",
              "briefKind": "breakdown"
            },
            "explore": {
              "description": "Explore the codebase with read/search tools and report findings",
              "backend": "opencode",
              "briefKind": "research"
            },
            "implement": {
              "description": "Apply the plan with minimal correct changes",
              "backend": "grok",
              "briefKind": "implement"
            },
            "verify": {
              "description": "Verify acceptance criteria and definition of done",
              "backend": "codex",
              "briefKind": "verify"
            },
            "research": {
              "description": "Gather facts; avoid unnecessary workspace writes",
              "backend": "opencode",
              "briefKind": "research"
            }
          },
          "scope": "resource",
          "description": "Named task type presets (id \u2192 { backend, model?, role?, briefKind?, description? }). Muster ships defaults (no model pins); edit in Settings or VS Code settings.json. Explicit empty map fails closed for create/delegate.",
          "additionalProperties": {
            "type": "object",
            "required": [
              "backend"
            ],
            "properties": {
              "backend": {
                "type": "string",
                "description": "ACP backend id (e.g. codex, grok, opencode)."
              },
              "model": {
                "type": "string",
                "description": "Optional ACP model id for this type."
              },
              "fallbacks": {
                "type": "array",
                "maxItems": 8,
                "description": "Task-type-specific ordered fallback chain. An explicit empty array disables global fallbacks for this type.",
                "items": {
                  "type": "object",
                  "required": [
                    "backend"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "backend": {
                      "type": "string"
                    },
                    "model": {
                      "type": "string"
                    }
                  }
                }
              },
              "role": {
                "type": "string",
                "enum": [
                  "coordinator",
                  "worker"
                ],
                "description": "Default child role (default worker)."
              },
              "briefKind": {
                "type": "string",
                "enum": [
                  "coordinate",
                  "plan",
                  "breakdown",
                  "implement",
                  "test",
                  "verify",
                  "research",
                  "generic"
                ],
                "description": "Default brief.kind preamble for children of this type."
              },
              "description": {
                "type": "string",
                "description": "Short selection help for coordinators (max 200 chars)."
              }
            }
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "muster",
          "title": "Muster",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "muster": [
        {
          "type": "webview",
          "id": "muster.chat",
          "name": "Muster"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run build:webview",
    "watch": "tsc -watch -p .",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "vscode:prepublish": "npm run compile",
    "mvp:claude": "tsx scripts/test-claude.ts",
    "mvp:grok": "tsx scripts/test-grok.ts",
    "mvp:kiro": "tsx scripts/test-kiro.ts",
    "mvp:codex": "tsx scripts/test-codex.ts",
    "mvp:opencode": "tsx scripts/test-opencode.ts",
    "smoke:child-model-opencode": "npm run compile && node scripts/smoke-child-model-opencode.mjs",
    "smoke:opencode-multi-session": "npm run compile && node scripts/smoke-opencode-multi-session.mjs",
    "vendor:codex-acp": "node scripts/vendor-codex-acp.mjs",
    "vendor:claude-acp": "node scripts/vendor-claude-acp.mjs",
    "mvp:task": "tsx scripts/test-task.ts",
    "mvp:bridge": "tsx scripts/test-bridge.ts",
    "test:agy-ask": "node scripts/test-agy-ask-mcp.mjs",
    "test": "vitest run",
    "test:task-audit": "node --test scripts/verify-task-model-ui-state-audit.test.mjs",
    "test:settings-docs": "node --test scripts/verify-settings-docs.test.mjs",
    "test:settings-live-evidence": "node --test scripts/verify-settings-live-host-evidence.test.mjs",
    "test:settings-webview": "playwright test e2e/muster-webview-state.spec.ts",
    "test:settings-acceptance": "npm test && npm run compile && npm run check:svelte && npm run test:source-boundary && npm run test:evidence && npm run test:settings-docs && npm run test:settings-live-evidence && npm run test:settings-webview",
    "test:webview": "playwright test e2e/muster-webview-state.spec.ts e2e/muster-webview-virtualization.spec.ts",
    "test:phase6-webview": "playwright test e2e/muster-webview-virtualization.spec.ts",
    "test:webview:visual": "playwright test e2e/visual/muster-webview.visual.spec.ts --project=visual-chromium",
    "test:presentation:visual": "playwright test e2e/visual/muster-presentation.visual.spec.ts --project=visual-chromium",
    "test:visual": "playwright test e2e/visual --project=visual-chromium",
    "test:visual:update": "playwright test e2e/visual --project=visual-chromium --update-snapshots",
    "test:visual:linux": "node scripts/run-visual-baselines.mjs",
    "test:visual:linux:update": "node scripts/run-visual-baselines.mjs --update",
    "test:presentation-integration": "vitest run src/task/presentation-tool-auth.test.ts src/host/presentation-tool-router.test.ts src/host/presentation-manager.test.ts src/host/presentation-panel-adapter.test.ts src/host/presentation-chat-link.test.ts src/host/presentation-revision-loop.test.ts src/host/webview-security.test.ts && npm run compile && npm run test:webview -- e2e/muster-presentation.spec.ts",
    "test:presentation-live-evidence": "node --test scripts/verify-presentation-live-host-evidence.test.mjs",
    "test:presentation-docs": "node --test scripts/verify-presentation-docs.test.mjs",
    "test:file-drop-live-evidence": "node --test scripts/verify-file-drop-live-host-evidence.test.mjs",
    "test:file-mention-autocomplete-live-evidence": "node --test scripts/verify-file-mention-autocomplete-live-host-evidence.test.mjs",
    "test:file-drop-docs": "node --test scripts/verify-file-drop-docs.test.mjs",
    "test:queue-live-inject-docs": "node --test scripts/verify-queue-live-inject-docs.test.mjs",
    "test:task-export-docs": "node --test scripts/verify-task-export-docs.test.mjs",
    "test:task-export-live-evidence": "node --test scripts/verify-task-export-live-host-evidence.test.mjs",
    "test:live-inject-smoke": "node --test scripts/verify-live-inject-smoke.test.mjs",
    "test:sqlite-extension-host": "node scripts/run-sqlite-extension-host-smoke.mjs",
    "test:sqlite-two-window-live-uat": "node scripts/run-sqlite-two-window-live-uat.mjs",
    "test:watch": "vitest",
    "check:svelte": "svelte-check --workspace webview --tsconfig ./tsconfig.json",
    "test:source-boundary": "node scripts/source-boundary-smoke.mjs && npm run test:repository-boundary",
    "test:repository-boundary": "node scripts/repository-boundary-smoke.mjs",
    "bench:sqlite-transcript": "tsx scripts/bench-sqlite-transcript.ts",
    "bench:phase4-release": "npm run compile && node --expose-gc dist/scripts/bench-phase4-release.js",
    "bench:phase4-release:assert": "npm run compile && node --expose-gc dist/scripts/bench-phase4-release.js --assert --iterations=12",
    "bench:phase6-webview": "npm run build:webview && node scripts/bench-phase6-webview.mjs",
    "test:evidence": "node --test scripts/verify-verification-evidence.test.mjs",
    "test:source-boundary:fixtures": "node --test scripts/source-boundary-smoke.test.mjs scripts/repository-boundary-smoke.test.mjs",
    "test:sqlite-storage-docs": "node --test scripts/verify-sqlite-storage-docs.test.mjs",
    "test:sqlite-packaged-fault-uat": "node scripts/run-sqlite-packaged-fault-uat.mjs",
    "test:sqlite-phase5-evidence": "node --test scripts/sqlite-phase5-evidence-schema.test.mjs scripts/verify-sqlite-phase5-evidence.test.mjs",
    "test:sqlite-phase6-evidence": "node --test scripts/sqlite-phase6-evidence-schema.test.mjs scripts/verify-sqlite-phase6-evidence.test.mjs",
    "mvp:grok-interrupt-and-send": "tsx scripts/test-grok-interrupt-and-send.ts",
    "test:webview:visual:linux": "node scripts/run-visual-baselines.mjs e2e/visual/muster-webview.visual.spec.ts",
    "test:webview:visual:linux:update": "node scripts/run-visual-baselines.mjs --update e2e/visual/muster-webview.visual.spec.ts",
    "test:presentation:visual:linux": "node scripts/run-visual-baselines.mjs e2e/visual/muster-presentation.visual.spec.ts",
    "test:presentation:visual:linux:update": "node scripts/run-visual-baselines.mjs --update e2e/visual/muster-presentation.visual.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "adm-zip": "^0.6.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/svelte-virtual": "3.13.32",
    "@tanstack/virtual-core": "3.17.4",
    "@vscode-elements/elements": "^2.5.1",
    "dompurify": "^3.4.11",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "mermaid": "^11.16.0"
  }
}
